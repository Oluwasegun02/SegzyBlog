{
  "builds": [{
      "src": "SegzyBlog/wsgi.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb", "runtime": "python3.9" }
  }],
  "routes": [
      {
          "src": "/(.*)",
          "dest": "SegzyBlog/wsgi.py"
      }
  ]
  "functions": {
      "api/*.js": {
        "runtime": "nodejs14.x"
      }
  }
}
